<clickhouse>
  <profiles>
    <umbrella_profile>
      <max_memory_usage>12000000000</max_memory_usage>
      <max_threads>8</max_threads>
      <readonly>0</readonly>
    </umbrella_profile>
  </profiles>

  <users>
    <umbrella>
      <password replace="1" from_env="CLICKHOUSE_PASSWORD" />
      <profile>umbrella_profile</profile>
      <quota>default</quota>
      <networks>
        <ip>::/0</ip>
      </networks>
    </umbrella>
  </users>
</clickhouse>
